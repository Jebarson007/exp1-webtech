<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Online Plant Nursery</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f2fff0;
            color: #243b1d;
        }

        div {
            padding: 15px;
        }

        #header {
            background-color: #90c878;
            text-align: center;
        }

        #menu {
            background-color: #2e6b2e;
            text-align: center;
        }

        #menu a {
            color: white;
            margin: 10px;
        }

        .content {
            width: 80%;
            margin: auto;
            background-color: white;
        }

        img {
            width: 500px;
            max-width: 100%;
            height: 220px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid black;
            padding: 6px;
            text-align: center;
        }

        th {
            background-color: #b8df9f;
        }

        #contact {
            background-color: #d7efcf;
            text-align: center;
        }
    </style>
</head>

<body id="top">
    <!-- Header Section -->
    <div id="header">
        <h1>Green Leaf Online Plant Nursery</h1>
        <p>Simple plants for a green and happy home.</p>
    </div>

    <!-- Menu Section -->
    <div id="menu">
        <a href="#about">About</a>
        <a href="#plants">Plants</a>
        <a href="#care">Plant Care</a>
        <a href="#contact">Contact</a>
        <a href="https://en.wikipedia.org/wiki/Plant_nursery" target="_blank">Learn More</a>
    </div>

    <!-- About Section -->
    <div class="content" id="about">
        <h2>About Our Nursery</h2>
        <p>
            We sell healthy indoor and outdoor plants at affordable prices.
            Beginners can also find easy plant-care tips on this page.
        </p>
        <h3>Click the Image to See Our Plants</h3>
        <a href="#plants">
            <img src="plant-nursery.jpg" alt="Small collection of nursery plants">
        </a>
    </div>

    <!-- Plant Table Section -->
    <div class="content" id="plants">
        <h2>Available Plants</h2>
        <table>
            <tr>
                <th>Plant</th>
                <th>Type</th>
                <th>Price</th>
            </tr>
            <tr>
                <td>Money Plant</td>
                <td>Indoor</td>
                <td>Rs. 150</td>
            </tr>
            <tr>
                <td>Rose Plant</td>
                <td>Flowering</td>
                <td>Rs. 200</td>
            </tr>
            <tr>
                <td>Aloe Vera</td>
                <td>Medicinal</td>
                <td>Rs. 120</td>
            </tr>
        </table>
    </div>

    <!-- Plant Care Section -->
    <div class="content" id="care">
        <h2>Plant Care</h2>
        <dl>
            <dt>Watering</dt>
            <dd>Water the plant when the top soil becomes dry.</dd>
            <dt>Sunlight</dt>
            <dd>Keep the plant in a place with suitable sunlight.</dd>
        </dl>

        <h3>How to Order</h3>
        <ol>
            <li>Choose a plant.
                <ol>
                    <li>Indoor plant</li>
                    <li>Outdoor plant</li>
                </ol>
            </li>
            <li>Call or email the nursery.</li>
            <li>Confirm the order.</li>
        </ol>

        <h3>Plant Categories</h3>
        <ul>
            <li>Indoor Plants
                <ul>
                    <li>Money Plant</li>
                    <li>Aloe Vera</li>
                </ul>
            </li>
            <li>Flowering Plants</li>
        </ul>
    </div>

    <!-- Contact Section -->
    <div id="contact">
        <h2>Contact Us</h2>
        <p>Email: <a href="mailto:greenleaf@example.com">greenleaf@example.com</a></p>
        <p>Phone: <a href="tel:+919876543210">+91 98765 43210</a></p>
        <p><a href="#care">Go to Plant Care Bookmark</a></p>
        <p><a href="#top">Back to Top</a></p>
    </div>
</body>
</html>
